rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: teams
    // Fields: name, logoUrl, wins, losses, pointsFor, pointsAgainst, rank
    //
    // Collection: players
    // Fields: name, teamId, number, position, avgPoints, avgRebounds, avgSteals, avgBlocks, gamesPlayed
    //
    // Collection: games
    // Fields: homeTeamId, awayTeamId, homeScore, awayScore, date, status, venue
    //
    // Collection: news
    // Fields: title, content, imageUrl, date
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "j2113715863@gmail.com");
    }

    // Rules
    match /teams/{teamId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /players/{playerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /games/{gameId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read, write: if request.auth.uid == userId || isAdmin();
    }
  }
}
